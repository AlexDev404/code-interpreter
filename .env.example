# look at ./app/shared/config.py

# Path inside the container where uploaded/generated files are stored.
# Must match the target of your volume mount.
CONTAINER_UPLOAD_PATH=/app/uploads

# Absolute path on the HOST machine where files are stored.
# This is what the Docker daemon uses as the bind-mount source for execution containers.
# Must be an absolute path. Must be volume-mounted to CONTAINER_UPLOAD_PATH.
# Example: HOST_FILE_UPLOAD_PATH=/tmp/code-interpreter-uploads
# HOST_FILE_UPLOAD_PATH=uploads  # <-- default (relative) only works with source builds

# Legacy: only needed when HOST_FILE_UPLOAD_PATH is relative.
# Set to the absolute path of your project root on the host.
# HOST_PATH=/home/user/code-interpreter

# Python execution image. Default is python:3.11-slim (lightweight).
# Override with jupyter/scipy-notebook:latest for numpy/pandas/matplotlib support.
# PY_CONTAINER_IMAGE=jupyter/scipy-notebook:latest