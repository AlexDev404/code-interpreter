# look at ./app/shared/config.py

# Name of the Docker named volume shared between the code-interpreter and
# execution containers. Must match the volume name in your compose file.
UPLOADS_VOLUME_NAME=ci-uploads

# Python execution image. Default is python:3.11-slim (lightweight).
# Override with jupyter/scipy-notebook:latest for numpy/pandas/matplotlib support.
# PY_CONTAINER_IMAGE=jupyter/scipy-notebook:latest